// Adaptive RSI Pro v7.3 Strategy Report - v7.2 baseline behavior + minimal correctness fixes
// MIT License - https://github.com/user/adaptive-rsi-pro
//
// 信号图例 / Signal Legend:
// ─────────────────────────────────────────
// 买入 BUY (底部):  🌟 MTF共振 | 💎 背离+极端 | 🔥 极端超卖 | ⬆️ 普通超卖 | ↗️ 看涨背离
// 卖出 SELL (顶部): 🌟 MTF共振 | 💎 背离+极端 | ❄️ 极端超买 | ⬇️ 普通超买 | ↘️ 看跌背离
// 状态 STATUS:      🟢 超卖 | 🟡 轻度超卖 | ⚪ 中性 | 🟠 轻度超买 | 🔴 超买
// ─────────────────────────────────────────

//@version=6
strategy("Adaptive RSI Pro Strategy Report", shorttitle="ARSI Pro STRAT", overlay=false, precision=2, max_lines_count=100, max_labels_count=100, max_bars_back=4500, pyramiding=0, commission_type=strategy.commission.percent, commission_value=0.05, slippage=2)

MAX_REQUEST_BARS = 1400
WEEKLY_REQUEST_BARS = 120

// ────────────────────────────────────────
// INPUTS
// ────────────────────────────────────────

grp_rsi = "═══ RSI Settings / RSI设置 ═══"
rsi_length = input.int(14, "RSI Length / RSI周期", minval=2, group=grp_rsi)
rsi_source = input.source(close, "RSI Source / 数据源", group=grp_rsi)

grp_adaptive = "═══ Adaptive Settings / 自适应设置 ═══"
lookback_mode = input.string("Auto", "Lookback Mode / 回看模式", options=["Auto", "Custom"], group=grp_adaptive, tooltip="Auto: 根据时间框架和RSI波动率自动计算\nCustom: 使用自定义值")
lookback_custom = input.int(252, "Custom Lookback / 自定义回看", minval=50, maxval=2000, group=grp_adaptive, tooltip="仅在 Custom 模式下使用。建议：日线252，4小时500，1小时750")
lookback_precision = input.string("Normal", "Precision / 精度", options=["High", "Normal", "Low"], group=grp_adaptive, tooltip="High(高精度): 需要更多数据，更准确\nNormal(平衡): 推荐设置\nLow(快适应): 更少数据，更快响应")
vol_history_mode = input.string("1 Year", "History Depth / 历史深度", options=["6 Months", "1 Year", "2 Years"], group=grp_adaptive, tooltip="波动率参考的历史时间长度\n自动根据时间框架转换为K线数量")

grp_visual = "═══ Visual Settings / 视觉设置 ═══"
visual_line_mode = input.string("Unified", "Threshold Line Mode / 阈值线模式", options=["Unified", "Z-Score", "Percentile", "Both"], group=grp_visual, tooltip="Unified(推荐): Z-Score线+百分位标注，兼顾严谨性和直观性\nZ-Score: 仅统计学阈值线(±2σ, ±1.5σ)\nPercentile: 仅百分位线(P5-P95)\nBoth: 同时显示两种")
show_fill = input.bool(true, "Show Gradient Fill / 显示渐变填充", group=grp_visual)
show_dashboard = input.bool(true, "Show Dashboard / 显示仪表盘", group=grp_visual)
dashboard_mode = input.string("Full", "Dashboard Mode / 面板模式", options=["Mobile", "Full"], group=grp_visual, tooltip="Mobile: 极简模式(3行)，适合手机\nFull: 完整信息")
dashboard_size = input.string("Normal", "Dashboard Size / 面板大小", options=["Tiny", "Small", "Normal", "Large"], group=grp_visual)
dashboard_transparency = input.int(30, "Dashboard Transparency / 面板透明度", minval=0, maxval=100, step=10, group=grp_visual)
color_bull = input.color(color.new(#00E676, 60), "Bullish Color / 牛市颜色", group=grp_visual)
color_bear = input.color(color.new(#FF5252, 60), "Bearish Color / 熊市颜色", group=grp_visual)
color_rsi = input.color(#FFEB3B, "RSI Line Color / RSI线颜色", group=grp_visual)

grp_alerts = "═══ Alert Settings / 警报设置 ═══"
normal_signal_mode = input.string("Smart", "Normal Signal Mode / 普通信号模式", options=["Off", "On", "Smart"], group=grp_alerts, tooltip="Off: 关闭普通信号\nOn: 总是显示，使用手动阈值\nSmart: 自动判断显示+自动阈值")
normal_threshold_manual = input.float(1.5, "Manual Threshold / 手动阈值 (On模式)", minval=1.0, maxval=2.0, step=0.1, group=grp_alerts, tooltip="仅On模式使用\n1.5σ ≈ P6.7/P93.3\n1.28σ ≈ P10/P90")
enable_signal_cooldown = input.bool(true, "Enable Signal Cooldown / 启用信号冷却", group=grp_alerts, tooltip="防止同一区域重复信号污染统计数据")
cooldown_mode = input.string("Smart", "Cooldown Mode / 冷却模式", options=["Smart", "Fixed"], group=grp_alerts, tooltip="Smart: 根据市场波动率自动调整冷却期\nFixed: 使用固定冷却期")
cooldown_bars_fixed = input.int(5, "Fixed Cooldown (Bars) / 固定冷却期", minval=1, maxval=20, group=grp_alerts, tooltip="Fixed模式下的冷却时间（K线数）")
enable_smart_alert = input.bool(true, "🎯 Smart Alert / 智能警报", group=grp_alerts, tooltip="V6动态警报：自动聚合所有信号到一条消息\n包含完整上下文（RSI值、Z-Score、百分位）\n实时触发，智能去重")
include_risk_in_alerts = input.bool(false, "Include Risk Hints in Alerts / 警报含风险提示", group=grp_alerts, tooltip="在警报消息中包含ATR止损/止盈建议\n默认关闭，避免消息过长")
alert_rr_ratio = input.float(2.0, "Risk-Reward Ratio / 风险回报比", minval=1.5, maxval=3.0, step=0.5, group=grp_alerts, tooltip="止盈/止损比例\n2.0 = 1:2 风险回报比")

grp_protection = "═══ Trend Protection / 趋势保护 ═══"
enable_trend_protection = input.bool(true, "Enable Trend Protection / 启用趋势保护", group=grp_protection, tooltip="使用周线趋势过滤极端风险：避免在周线极端下跌中抄底")
protection_level = input.string("Moderate", "Protection Level / 保护级别", options=["Aggressive", "Moderate", "Loose"], group=grp_protection, tooltip="Aggressive: 周线必须上升趋势\nModerate(推荐): 排除周线极端下跌\nLoose: 仅排除周线RSI<20的极端情况")
enable_percentile_confirm = input.bool(false, "🎯 Percentile Confirm / 百分位确认", group=grp_protection, tooltip="极端信号需同时满足 Z-Score(-2σ) 和 Percentile(P5/P95)\n可减少波动率变化时的假信号，提升胜率\n适用于波动率变化较大的市场\n---\nExtreme signals require both Z-Score AND Percentile\nReduces false signals when volatility changes")

grp_volume = "═══ Volume Confirmation / 成交量确认 ═══"
enable_volume_scoring = input.bool(true, "Enable Volume Scoring / 启用成交量评分", group=grp_volume, tooltip="成交量作为信号质量评分项，不强制过滤")
volume_surge_mult = input.float(1.5, "Volume Surge Multiplier / 放量倍数", minval=1.0, maxval=3.0, step=0.1, group=grp_volume, tooltip="高于均量X倍视为放量")

grp_mtf = "═══ Multi-Timeframe / 多时间框架 ═══"
enable_mtf = input.bool(true, "Enable MTF RSI / 启用多时间框架", group=grp_mtf)
mtf_mode = input.string("Auto", "MTF Mode / 模式", options=["Auto", "Manual"], group=grp_mtf, tooltip="Auto: 根据分形逻辑自动选择更小周期 (向下分形)\nManual: 使用下方手动设置")
mtf_tf1_input = input.timeframe("60", "Manual TF1 / 手动周期1", group=grp_mtf)
mtf_tf2_input = input.timeframe("240", "Manual TF2 / 手动周期2", group=grp_mtf)
mtf_tf3_input = input.timeframe("D", "Manual TF3 / 手动周期3", group=grp_mtf)

grp_stats = "═══ Signal Statistics / 信号统计 ═══"
enable_stats = input.bool(true, "Enable Statistics / 启用统计", group=grp_stats)
stats_mode = input.string("Ranking", "Stats Mode / 统计模式", options=["Signal Type", "Grade", "Ranking"], group=grp_stats, tooltip="Signal Type: 按信号类型统计\nGrade: 按质量等级统计\nRanking: 交叉排行榜（信号×等级）")
stats_forward_bars = input.int(20, "Forward Bars / 前瞻K线数", minval=5, maxval=100, group=grp_stats, tooltip="信号触发后多少根K线计算收益")
enable_stats_filter = input.bool(true, "Enable Stats Filter / 启用统计过滤", group=grp_stats, tooltip="基于历史统计数据过滤低质量信号\n根据样本数和胜率自动过滤")
stats_min_samples = input.int(20, "Min Samples / 最小样本数", minval=5, maxval=50, group=grp_stats, tooltip="信号组合需要的最小样本数\n≥20为统计可靠")
stats_min_winrate = input.float(55.0, "Min Adjusted WinRate / 最小调整胜率", minval=50.0, maxval=70.0, step=1.0, group=grp_stats, tooltip="信号组合需要的最小贝叶斯调整胜率\n55%为建议值")
stats_filter_mode = input.string("Alert Only", "Filter Mode / 过滤模式", options=["Alert Only", "Soft", "Hard"], group=grp_stats, tooltip="Alert Only: 仅过滤警报，图表显示所有信号\nSoft: 低质量信号降级显示\nHard: 完全隐藏低质量信号")

grp_harness = "═══ Strategy Report / 策略回测 ═══"
harness_trade_side = input.string("Long Only", "Trade Side / 交易方向", options=["Long Only", "Short Only", "Both"], group=grp_harness, tooltip="Long Only: 仅做多，卖出信号只平多\nShort Only: 仅做空，买入信号只平空\nBoth: 双向切换，买卖信号会反手")
harness_backtest_mode = input.string("Production", "Backtest Mode / 回测模式", options=["Baseline", "Production"], group=grp_harness, tooltip="Baseline: raw v7.2 signals, no stats filter\nProduction: gate-passing production alert signals; not exact intrabar alert delivery\nBaseline: 使用 7.2 原始信号，不加统计过滤\nProduction: 使用通过正式警报 gate/过滤的信号，不精确模拟盘中 alert 投递")

grp_divergence = "═══ Divergence Settings / 背离设置 ═══"
enable_divergence = input.bool(true, "Enable Divergence Detection / 启用背离检测", group=grp_divergence)
div_mode = input.string("Auto", "Divergence Mode / 背离模式", options=["Auto", "Low Vol", "Normal", "High Vol", "Crypto", "Custom"], group=grp_divergence, tooltip="Auto: 根据ATR自动判断\nLow Vol: 蓝筹/ETF\nNormal: 一般股票\nHigh Vol: 成长/小盘\nCrypto: 加密货币")
div_lookback_custom = input.int(5, "Custom Lookback / 自定义回看", minval=2, maxval=20, group=grp_divergence, tooltip="仅在 Custom 模式下使用")
div_range_custom = input.int(60, "Custom Range / 自定义范围", minval=20, maxval=200, group=grp_divergence, tooltip="仅在 Custom 模式下使用")

// 波动性检测
atr_20 = ta.atr(20)
avg_volatility = ta.sma(atr_20 / close * 100, 252)
auto_vol_type = avg_volatility > 6 ? "Crypto" : avg_volatility > 3 ? "High Vol" : avg_volatility > 1 ? "Normal" : "Low Vol"

strategy_allowed_direction = harness_trade_side == "Long Only" ? strategy.direction.long :
                             harness_trade_side == "Short Only" ? strategy.direction.short :
                             strategy.direction.all
strategy.risk.allow_entry_in(strategy_allowed_direction)
bool harness_use_production = harness_backtest_mode == "Production"

// ADX 趋势强度检测 (v6.9)
[adx_di_plus, adx_di_minus, adx_value] = ta.dmi(14, 14)
adx_is_trending = adx_value > 25
adx_trend_up = adx_di_plus > adx_di_minus
adx_trend_down = adx_di_minus > adx_di_plus

// 智能冷却期基础值
base_cooldown = avg_volatility > 6 ? 2 : avg_volatility > 3 ? 3 : avg_volatility > 1 ? 5 : 8
vol_short_term = ta.sma(atr_20 / close * 100, 20)

// 智能普通信号阈值（基于波动率）
auto_normal_threshold = avg_volatility > 6 ? 1.0 : avg_volatility > 3 ? 1.28 : avg_volatility > 1 ? 1.5 : 1.8
normal_threshold = normal_signal_mode == "On" ? normal_threshold_manual : auto_normal_threshold

// 背离模式参数
active_div_mode = div_mode == "Auto" ? auto_vol_type : div_mode
div_lookback = div_mode == "Custom" ? div_lookback_custom : active_div_mode == "Low Vol" ? 3 : active_div_mode == "Normal" ? 5 : active_div_mode == "High Vol" ? 7 : 10
div_range = div_mode == "Custom" ? div_range_custom : active_div_mode == "Low Vol" ? 40 : active_div_mode == "Normal" ? 60 : active_div_mode == "High Vol" ? 80 : 120
chart_tf_seconds = timeframe.in_seconds(timeframe.period)

// ────────────────────────────────────────
// RSI CALCULATION
// ────────────────────────────────────────

rsi = ta.rsi(rsi_source, rsi_length)

// ────────────────────────────────────────
// DYNAMIC LOOKBACK CALCULATION
// ────────────────────────────────────────

vol_short_period = rsi_length * 4
vol_history_days = vol_history_mode == "6 Months" ? 126 : vol_history_mode == "1 Year" ? 252 : 504
tf_minutes = timeframe.in_seconds(timeframe.period) / 60
// 正确计算每日对应的K线数：周线=1/5天，月线=1/21天
bars_per_day = timeframe.ismonthly ? 1.0 / 21 : timeframe.isweekly ? 1.0 / 5 : timeframe.isdaily ? 1 : math.ceil(1440 / tf_minutes)
vol_long_period = math.min(4500, int(vol_history_days * bars_per_day))

vol_short = nz(ta.stdev(rsi, vol_short_period), 10)
vol_long = nz(ta.stdev(rsi, vol_long_period), 10)
vol_base = vol_long * 0.7 + vol_short * 0.3
recent_high = vol_short > vol_long * 1.2
vol_dynamic = recent_high ? (vol_short * 0.6 + vol_long * 0.4) : vol_base

// 智能冷却期动态调整
price_vol_active = vol_short_term > avg_volatility * 1.2
rsi_vol_active = vol_short > vol_long * 1.2
market_active = price_vol_active or rsi_vol_active
smart_cooldown_bars = market_active ? math.max(base_cooldown - 1, 1) : base_cooldown
cooldown_bars = cooldown_mode == "Smart" ? smart_cooldown_bars : cooldown_bars_fixed

// 统计样本量计算: n = (Z × σ / E)²
rsi_vol_bootstrap = math.max(vol_dynamic, vol_long * 0.8)
stat_lookback = math.max(50, math.pow(1.96 * rsi_vol_bootstrap / 5, 2))
stat_error = lookback_precision == "High" ? 2.0 : lookback_precision == "Normal" ? 2.5 : 3.5
stat_required = math.pow(1.96 * rsi_vol_bootstrap / stat_error, 2)

// Smart Lookback: 基于波动率和统计需求的动态范围
// 价格波动率决定基础范围
price_based_min = avg_volatility > 6 ? 50 : avg_volatility > 3 ? 80 : avg_volatility > 1 ? 150 : 200
price_based_max = avg_volatility > 6 ? 400 : avg_volatility > 3 ? 600 : avg_volatility > 1 ? 800 : 1000
// 统计需求决定最小值下限（确保 lookback ≈ stat_required）
stat_based_min = math.max(50, int(stat_required * 0.8))
// 取价格波动和统计需求中较高值作为最终最小值
lookback_min = math.max(price_based_min, stat_based_min)
lookback_max = price_based_max

// 分布宽度反馈（使用前一个bar的spread，形成反馈环）
// 只在分布窄时增加lookback，分布宽时不减少（避免低于统计需求）
var float prev_spread = 30.0
spread_factor = prev_spread < 20 ? 1.3 : 1.0

// 最终 lookback = 统计基础 × 反馈因子，保守地不低于 stat_required
auto_lookback_base = math.max(stat_required, stat_required * spread_factor)
auto_lookback = int(math.max(lookback_min, math.min(lookback_max, auto_lookback_base)))
lookback = lookback_mode == "Custom" ? math.min(1000, lookback_custom) : auto_lookback

// 健康度指标
health_sample_coverage = bar_index >= lookback * 0.8
health_stat_valid = lookback >= stat_required * 0.9
theoretical_lookback = int(math.max(100, math.min(2000, math.ceil(stat_lookback))))

// ────────────────────────────────────────
// ADAPTIVE PERCENTILE CALCULATION
// ────────────────────────────────────────

rsi_p5  = ta.percentile_nearest_rank(rsi, lookback, 5)
rsi_p10 = ta.percentile_nearest_rank(rsi, lookback, 10)
rsi_p25 = ta.percentile_nearest_rank(rsi, lookback, 25)
rsi_p50 = ta.percentile_nearest_rank(rsi, lookback, 50)
rsi_p75 = ta.percentile_nearest_rank(rsi, lookback, 75)
rsi_p90 = ta.percentile_nearest_rank(rsi, lookback, 90)
rsi_p95 = ta.percentile_nearest_rank(rsi, lookback, 95)
current_spread = rsi_p95 - rsi_p5
health_distribution_spread = current_spread >= 15
prev_spread := current_spread

// ────────────────────────────────────────
// RSI Z-SCORE CALCULATION
// ────────────────────────────────────────

rsi_mean = ta.sma(rsi, lookback)
rsi_stdev = ta.stdev(rsi, lookback)
rsi_zscore = rsi_stdev != 0 ? (rsi - rsi_mean) / rsi_stdev : 0

zscore_upper_2 = rsi_mean + rsi_stdev * 2
zscore_upper_1_5 = rsi_mean + rsi_stdev * 1.5
zscore_lower_1_5 = rsi_mean - rsi_stdev * 1.5
zscore_lower_2 = rsi_mean - rsi_stdev * 2

// ────────────────────────────────────────
// Z-SCORE ↔ PERCENTILE CONVERSION
// ────────────────────────────────────────

f_zscore_to_percentile(_zscore) =>
    _z = math.abs(_zscore)
    _pct = _z >= 3.0 ? 99.9 :
           _z >= 2.5 ? 99.4 :
           _z >= 2.0 ? 97.7 :
           _z >= 1.96 ? 97.5 :
           _z >= 1.5 ? 93.3 :
           _z >= 1.28 ? 90.0 :
           _z >= 1.0 ? 84.1 :
           _z >= 0.67 ? 75.0 :
           _z >= 0.5 ? 69.1 :
           _z >= 0.25 ? 59.9 : 50.0
    _zscore >= 0 ? _pct : 100 - _pct

f_percentile_zscore_range(_pct) =>
    _result = _pct < 2.3 ? " (< −2σ)" :
              _pct <= 6.7 ? " (−1.5σ ~ −2σ)" :
              _pct <= 15.9 ? " (−1σ ~ −1.5σ)" :
              _pct >= 97.7 ? " (> +2σ)" :
              _pct >= 93.3 ? " (+1.5σ ~ +2σ)" :
              _pct >= 84.1 ? " (+1σ ~ +1.5σ)" : ""
    _result

// ────────────────────────────────────────
// TREND PROTECTION (Weekly-based)
// ────────────────────────────────────────

[weekly_rsi, weekly_sma20, weekly_sma50] = request.security(
    syminfo.tickerid, "W",
    [ta.rsi(close, 14)[1], ta.sma(close, 20)[1], ta.sma(close, 50)[1]],
    lookahead=barmerge.lookahead_on,
    calc_bars_count=WEEKLY_REQUEST_BARS
)

weekly_uptrend = weekly_sma20 > weekly_sma50
weekly_extreme_bearish = weekly_rsi < 30 and weekly_sma20 < weekly_sma50
weekly_ultra_bearish = weekly_rsi < 20

trend_allows_buy = protection_level == "Aggressive" ? weekly_uptrend : protection_level == "Moderate" ? not weekly_extreme_bearish : not weekly_ultra_bearish

weekly_downtrend = weekly_sma20 < weekly_sma50
weekly_extreme_bullish = weekly_rsi > 70 and weekly_sma20 > weekly_sma50
weekly_ultra_bullish = weekly_rsi > 80

trend_allows_sell = protection_level == "Aggressive" ? weekly_downtrend : protection_level == "Moderate" ? not weekly_extreme_bullish : not weekly_ultra_bullish

protection_status = not enable_trend_protection ? "OFF" : trend_allows_buy and trend_allows_sell ? "✓" : trend_allows_buy ? "BUY✓" : trend_allows_sell ? "SELL✓" : "⚠️"

// 智能普通信号显示逻辑
weekly_neutral = not weekly_extreme_bearish and not weekly_extreme_bullish
auto_show_normal = weekly_neutral
show_normal_signals = normal_signal_mode == "Off" ? false : normal_signal_mode == "On" ? true : auto_show_normal

// ────────────────────────────────────────
// VOLUME CONFIRMATION
// ────────────────────────────────────────

vol_sma20 = ta.sma(volume, 20)
volume_ratio = vol_sma20 > 0 ? volume / vol_sma20 : 1.0

volume_surge = volume_ratio >= volume_surge_mult
volume_normal = volume_ratio >= 0.8 and volume_ratio < volume_surge_mult
volume_low = volume_ratio < 0.8
volume_score = volume_surge ? 20 : volume_normal ? 10 : 0

// ────────────────────────────────────────
// MULTI-TIMEFRAME RSI
// ────────────────────────────────────────

f_get_auto_timeframes() =>
    string t1 = "60"
    string t2 = "240"
    string t3 = "D"

    if timeframe.isdaily
        t1 := "60"
        t2 := "240"
        t3 := "D"
    else if timeframe.in_seconds(timeframe.period) >= 14400
        t1 := "15"
        t2 := "60"
        t3 := "240"
    else if timeframe.in_seconds(timeframe.period) >= 3600
        t1 := "5"
        t2 := "15"
        t3 := "60"
    else if timeframe.in_seconds(timeframe.period) >= 900
        t1 := "1"
        t2 := "5"
        t3 := "15"
    else
        t1 := "1"
        t2 := "3"
        t3 := "5"

    [t1, t2, t3]

[auto_t1, auto_t2, auto_t3] = f_get_auto_timeframes()
active_tf1 = mtf_mode == "Auto" ? auto_t1 : mtf_tf1_input
active_tf2 = mtf_mode == "Auto" ? auto_t2 : mtf_tf2_input
active_tf3 = mtf_mode == "Auto" ? auto_t3 : mtf_tf3_input

f_status(_rsi, _p10, _p90) =>
    na(_rsi) or na(_p10) or na(_p90) ? 0 : _rsi < _p10 ? 1 : _rsi > _p90 ? -1 : 0

f_mtf_status_expr(_lookback) =>
    _rsi = ta.rsi(rsi_source, rsi_length)
    _p10 = ta.percentile_nearest_rank(_rsi, _lookback, 10)
    _p90 = ta.percentile_nearest_rank(_rsi, _lookback, 90)
    f_status(_rsi, _p10, _p90)

f_array_last_status(array<int> _values) =>
    _size = array.size(_values)
    _size > 0 ? array.get(_values, _size - 1) : 0

f_tf_seconds(_tf) =>
    _seconds = timeframe.in_seconds(_tf)
    na(_seconds) ? chart_tf_seconds : _seconds

f_mtf_status(_tf) =>
    _tf_seconds = f_tf_seconds(_tf)
    array<int> _statuses = request.security_lower_tf(
        syminfo.tickerid,
        _tf,
        f_mtf_status_expr(lookback),
        ignore_invalid_timeframe=true,
        calc_bars_count=MAX_REQUEST_BARS
    )
    _current = f_status(rsi, rsi_p10, rsi_p90)
    _htf_status = request.security(
        syminfo.tickerid,
        _tf,
        f_mtf_status_expr(lookback)[1],
        lookahead=barmerge.lookahead_on,
        calc_bars_count=MAX_REQUEST_BARS
    )
    _tf_seconds < chart_tf_seconds ? f_array_last_status(_statuses) : _tf_seconds == chart_tf_seconds ? _current : nz(_htf_status, _current)

f_tf_display(_tf) =>
    if str.contains(_tf, "D") or str.contains(_tf, "W") or str.contains(_tf, "M")
        _tf
    else
        int_tf = str.tonumber(_tf)
        if not na(int_tf)
            if int_tf < 60
                str.format("{0}m", int_tf)
            else if int_tf % 60 == 0
                str.format("{0}h", int_tf / 60)
            else
                str.format("{0}m", int_tf)
        else
            _tf

mtf_tf1_display = f_tf_display(active_tf1)
mtf_tf2_display = f_tf_display(active_tf2)
mtf_tf3_display = f_tf_display(active_tf3)
current_tf_display = f_tf_display(timeframe.period)

status_tf1 = enable_mtf ? f_mtf_status(active_tf1) : 0
status_tf2 = enable_mtf ? f_mtf_status(active_tf2) : 0
status_tf3 = enable_mtf ? f_mtf_status(active_tf3) : 0
status_current = f_status(rsi, rsi_p10, rsi_p90)

tf1_is_current = mtf_tf1_display == current_tf_display
tf2_is_current = mtf_tf2_display == current_tf_display
tf3_is_current = mtf_tf3_display == current_tf_display

valid_tf_count = 1 + (tf1_is_current ? 0 : 1) + (tf2_is_current ? 0 : 1) + (tf3_is_current ? 0 : 1)

// 简单计数（用于显示）
oversold_count = (status_current == 1 ? 1 : 0) + (not tf1_is_current and status_tf1 == 1 ? 1 : 0) + (not tf2_is_current and status_tf2 == 1 ? 1 : 0) + (not tf3_is_current and status_tf3 == 1 ? 1 : 0)
overbought_count = (status_current == -1 ? 1 : 0) + (not tf1_is_current and status_tf1 == -1 ? 1 : 0) + (not tf2_is_current and status_tf2 == -1 ? 1 : 0) + (not tf3_is_current and status_tf3 == -1 ? 1 : 0)

// v6.8: 加权共振 - TF3权重2, 其他权重1, 满分5
oversold_weighted = (status_current == 1 ? 1 : 0) + (not tf1_is_current and status_tf1 == 1 ? 1 : 0) + (not tf2_is_current and status_tf2 == 1 ? 1 : 0) + (not tf3_is_current and status_tf3 == 1 ? 2 : 0)
overbought_weighted = (status_current == -1 ? 1 : 0) + (not tf1_is_current and status_tf1 == -1 ? 1 : 0) + (not tf2_is_current and status_tf2 == -1 ? 1 : 0) + (not tf3_is_current and status_tf3 == -1 ? 2 : 0)

// 最大加权分数
max_weighted = 1 + (tf1_is_current ? 0 : 1) + (tf2_is_current ? 0 : 1) + (tf3_is_current ? 0 : 2)

// 共振触发：加权分数 >= 4（满分5），或当周期数少时全部一致
oversold_resonance = oversold_weighted >= 4 or (valid_tf_count <= 3 and oversold_count == valid_tf_count)
overbought_resonance = overbought_weighted >= 4 or (valid_tf_count <= 3 and overbought_count == valid_tf_count)

// ────────────────────────────────────────
// SIGNAL STATISTICS
// ────────────────────────────────────────

type SignalStats
    int count = 0
    float total_return = 0.0
    int wins = 0

method update(SignalStats this, bool triggered, float ret) =>
    if triggered
        this.count += 1
        this.total_return += ret
        if ret > 0
            this.wins += 1

method get_avg(SignalStats this) =>
    this.count > 0 ? this.total_return / this.count : 0.0

method get_winrate(SignalStats this) =>
    this.count > 0 ? float(this.wins) / this.count * 100 : 0.0

method get_reliability(SignalStats this) =>
    this.count >= 20 ? "✓" : this.count >= 5 ? "⚠️" : "❌"

method get_adjusted_winrate(SignalStats this) =>
    if this.count < 5
        na
    else
        prior = 50.0
        confidence = math.min(1.0, float(this.count) / 20.0)
        raw_rate = this.get_winrate()
        prior * (1 - confidence) + raw_rate * confidence

STATS_SIGNAL_MTF = 0
STATS_SIGNAL_DIV = 1
STATS_SIGNAL_EXT = 2
STATS_SIGNAL_NORM = 3
STATS_SIGNAL_COUNT = 4

STATS_GRADE_COUNT = 4
STATS_DIR_BUY = 0
STATS_DIR_SELL = 1
STATS_DIR_COUNT = 2

STATS_SIGNAL_BUCKETS = STATS_SIGNAL_COUNT * STATS_DIR_COUNT
STATS_GRADE_BUCKETS = STATS_GRADE_COUNT * STATS_DIR_COUNT
STATS_RANKING_BUCKETS = STATS_SIGNAL_COUNT * STATS_GRADE_COUNT * STATS_DIR_COUNT
STATS_RANKING_BUCKETS_PER_SIGNAL = STATS_GRADE_COUNT * STATS_DIR_COUNT

var array<SignalStats> signal_type_stats = array.new<SignalStats>(0)
var array<SignalStats> grade_stats = array.new<SignalStats>(0)
var array<SignalStats> ranking_stats = array.new<SignalStats>(0)

if array.size(signal_type_stats) == 0
    for i = 0 to STATS_SIGNAL_BUCKETS - 1
        array.push(signal_type_stats, SignalStats.new())
    for i = 0 to STATS_GRADE_BUCKETS - 1
        array.push(grade_stats, SignalStats.new())
    for i = 0 to STATS_RANKING_BUCKETS - 1
        array.push(ranking_stats, SignalStats.new())

f_dir_bucket_index(_is_buy) =>
    _is_buy ? STATS_DIR_BUY : STATS_DIR_SELL

f_signal_kind_index(_is_mtf, _is_div, _is_ext) =>
    _is_mtf ? STATS_SIGNAL_MTF : _is_div ? STATS_SIGNAL_DIV : _is_ext ? STATS_SIGNAL_EXT : STATS_SIGNAL_NORM

f_grade_bucket_index_value(_grade) =>
    _grade == "A" ? 0 : _grade == "B" ? 1 : _grade == "C" ? 2 : 3

f_grade_value(_grade_idx) =>
    _grade_idx == 0 ? "A" : _grade_idx == 1 ? "B" : _grade_idx == 2 ? "C" : "D"

f_signal_type_bucket_index(_is_buy, _signal_idx) =>
    _signal_idx * STATS_DIR_COUNT + f_dir_bucket_index(_is_buy)

f_grade_bucket_index(_is_buy, _grade) =>
    f_grade_bucket_index_value(_grade) * STATS_DIR_COUNT + f_dir_bucket_index(_is_buy)

f_ranking_bucket_index(_is_buy, _signal_idx, _grade) =>
    (_signal_idx * STATS_GRADE_COUNT + f_grade_bucket_index_value(_grade)) * STATS_DIR_COUNT + f_dir_bucket_index(_is_buy)

f_update_stats_bucket(array<SignalStats> _stats, int _idx, bool _triggered, float _ret) =>
    _bucket = array.get(_stats, _idx)
    _bucket.update(_triggered, _ret)

f_ranking_signal_number(_idx) =>
    _idx < 8 ? 1 : _idx < 16 ? 2 : _idx < 24 ? 3 : 4

f_ranking_grade_index(_idx) =>
    _idx_in_signal = _idx % STATS_RANKING_BUCKETS_PER_SIGNAL
    _idx_in_signal < 2 ? 0 : _idx_in_signal < 4 ? 1 : _idx_in_signal < 6 ? 2 : 3

f_ranking_direction_number(_idx) =>
    _idx % STATS_DIR_COUNT == STATS_DIR_BUY ? 1 : 2

f_signal_type_dashboard_label(_signal_idx, _is_buy) =>
    _signal_idx == STATS_SIGNAL_MTF ? (_is_buy ? "🌟MTF Buy" : "🌟MTF Sell") :
     _signal_idx == STATS_SIGNAL_DIV ? (_is_buy ? "💎Div Buy" : "💎Div Sell") :
     _signal_idx == STATS_SIGNAL_EXT ? (_is_buy ? "🔥Ext Buy" : "❄️Ext Sell") :
     _is_buy ? "⬆️Norm Buy" : "⬇️Norm Sell"

f_signal_type_dashboard_color(_signal_idx, _is_buy, _bull, _bear) =>
    _signal_idx == STATS_SIGNAL_MTF ? #FFD700 :
     _signal_idx == STATS_SIGNAL_DIV ? #00BCD4 :
     _signal_idx == STATS_SIGNAL_EXT ? (_is_buy ? _bull : _bear) :
     color.new(_is_buy ? _bull : _bear, 30)

f_grade_dashboard_color(_grade_idx) =>
    _grade_idx == 0 ? #FFD700 : _grade_idx == 1 ? #4CAF50 : _grade_idx == 2 ? #FF9800 : #9E9E9E

f_stats_wr_text(SignalStats _stats) =>
    _stats.count >= 5 ? str.format("{0,number,#}%", _stats.get_adjusted_winrate()) : "--"

f_stats_avg_wr_text(SignalStats _stats) =>
    _stats.count >= 5 ? str.format("{0,number,+#.1;-#.1}%|{1,number,#}%", _stats.get_avg(), _stats.get_adjusted_winrate()) : "--|--"


// ────────────────────────────────────────
// DIVERGENCE DETECTION (v6.8 重构: 单锚点 + offset绘制)
// ────────────────────────────────────────

// 只用 price pivot 作为锚点，取该 bar 的 RSI 值进行比较
// 这样可以捕获更多有效背离，避免要求 RSI 和 price 同时 pivot
price_pivot_low = ta.pivotlow(low, div_lookback, div_lookback)
price_pivot_high = ta.pivothigh(high, div_lookback, div_lookback)

var float prev_price_low = na
var float prev_rsi_at_low = na  // 改名：在 price pivot 点的 RSI 值
var int prev_low_bar = na
var float prev_price_high = na
var float prev_rsi_at_high = na  // 改名：在 price pivot 点的 RSI 值
var int prev_high_bar = na

var bool bullish_divergence = false
var bool bearish_divergence = false

if enable_divergence
    // 看涨背离：价格创新低，但 RSI 未创新低（只需 price pivot）
    if not na(price_pivot_low)
        current_bar = bar_index - div_lookback
        current_rsi_at_pivot = rsi[div_lookback]  // 取 price pivot 点的 RSI
        if not na(prev_price_low) and not na(prev_rsi_at_low)
            bars_since = current_bar - prev_low_bar
            // 价格更低，但 RSI 更高 = 看涨背离
            if bars_since <= div_range and low[div_lookback] < prev_price_low and current_rsi_at_pivot > prev_rsi_at_low
                bullish_divergence := true
            else
                bullish_divergence := false
        else
            bullish_divergence := false
        prev_price_low := low[div_lookback]
        prev_rsi_at_low := current_rsi_at_pivot
        prev_low_bar := current_bar
    else
        bullish_divergence := false

    // 看跌背离：价格创新高，但 RSI 未创新高（只需 price pivot）
    if not na(price_pivot_high)
        current_bar = bar_index - div_lookback
        current_rsi_at_pivot = rsi[div_lookback]  // 取 price pivot 点的 RSI
        if not na(prev_price_high) and not na(prev_rsi_at_high)
            bars_since = current_bar - prev_high_bar
            // 价格更高，但 RSI 更低 = 看跌背离
            if bars_since <= div_range and high[div_lookback] > prev_price_high and current_rsi_at_pivot < prev_rsi_at_high
                bearish_divergence := true
            else
                bearish_divergence := false
        else
            bearish_divergence := false
        prev_price_high := high[div_lookback]
        prev_rsi_at_high := current_rsi_at_pivot
        prev_high_bar := current_bar
    else
        bearish_divergence := false

// ────────────────────────────────────────
// CONFIRMATION & REVERSAL SIGNALS
// ────────────────────────────────────────

rsi_pivot_low_current = ta.pivotlow(rsi, 3, 1)
rsi_pivot_high_current = ta.pivothigh(rsi, 3, 1)

// Percentile confirm for [1] indexed checks (inline to avoid ordering issues)
bool pct_ok_buy_1 = not enable_percentile_confirm or na(rsi_p5[1]) or (rsi[1] <= rsi_p5[1])
bool pct_ok_sell_1 = not enable_percentile_confirm or na(rsi_p95[1]) or (rsi[1] >= rsi_p95[1])

bool confirmation_buy = not na(rsi_pivot_low_current) and rsi_zscore[1] < -2 and pct_ok_buy_1
bool confirmation_sell = not na(rsi_pivot_high_current) and rsi_zscore[1] > 2 and pct_ok_sell_1

bool reversal_buy = ta.crossover(rsi_zscore, -2) and rsi_zscore[1] < -2 and pct_ok_buy_1
bool reversal_sell = ta.crossunder(rsi_zscore, 2) and rsi_zscore[1] > 2 and pct_ok_sell_1

// ────────────────────────────────────────
// REAL-TIME DIVERGENCE
// ────────────────────────────────────────

realtime_lookback = 20
lowest_price_20 = ta.lowest(low, realtime_lookback)
highest_price_20 = ta.highest(high, realtime_lookback)
lowest_rsi_20 = ta.lowest(rsi, realtime_lookback)
highest_rsi_20 = ta.highest(rsi, realtime_lookback)

price_near_low = low <= lowest_price_20 * 1.01
rsi_not_at_low = rsi > lowest_rsi_20 + 3
bool realtime_bullish_div = price_near_low and rsi_not_at_low and rsi_zscore < -1.5

price_near_high = high >= highest_price_20 * 0.99
rsi_not_at_high = rsi < highest_rsi_20 - 3
bool realtime_bearish_div = price_near_high and rsi_not_at_high and rsi_zscore > 1.5

// ────────────────────────────────────────
// VISUAL PLOTTING
// ────────────────────────────────────────

show_unified = visual_line_mode == "Unified"
show_zscore_lines = show_unified or visual_line_mode == "Z-Score" or visual_line_mode == "Both"
show_percentile_lines = visual_line_mode == "Percentile" or visual_line_mode == "Both"

zscore_extreme_color = show_zscore_lines ? (visual_line_mode == "Both" ? 50 : 70) : 100
zscore_normal_color = show_zscore_lines ? (visual_line_mode == "Both" ? 60 : 80) : 100

plot(show_zscore_lines ? zscore_upper_2 : na, "±2σ (≈P98)", color=color.new(color_bear, zscore_extreme_color), linewidth=2, style=plot.style_line)
plot(show_zscore_lines ? zscore_upper_1_5 : na, "±1.5σ (≈P93)", color=color.new(color_bear, zscore_normal_color), linewidth=1, style=plot.style_circles)
plot(show_zscore_lines ? zscore_lower_1_5 : na, "±1.5σ (≈P7)", color=color.new(color_bull, zscore_normal_color), linewidth=1, style=plot.style_circles)
plot(show_zscore_lines ? zscore_lower_2 : na, "±2σ (≈P2)", color=color.new(color_bull, zscore_extreme_color), linewidth=2, style=plot.style_line)

percentile_line_transparency = show_percentile_lines ? (visual_line_mode == "Both" ? 85 : 70) : 100

p95_line = plot(rsi_p95, "P95", color=color.new(color_bear, percentile_line_transparency), linewidth=1)
p90_line = plot(rsi_p90, "P90", color=color.new(color_bear, percentile_line_transparency), linewidth=1, style=plot.style_circles)
p75_line = plot(rsi_p75, "P75", color=color.new(color.gray, percentile_line_transparency), linewidth=1)
p50_line = plot(rsi_p50, "P50", color=color.new(color.white, 50), linewidth=2, style=plot.style_stepline)
p25_line = plot(rsi_p25, "P25", color=color.new(color.gray, percentile_line_transparency), linewidth=1)
p10_line = plot(rsi_p10, "P10", color=color.new(color_bull, percentile_line_transparency), linewidth=1, style=plot.style_circles)
p5_line  = plot(rsi_p5, "P5", color=color.new(color_bull, percentile_line_transparency), linewidth=1)

rsi_line = plot(rsi, "RSI", color=color_rsi, linewidth=2)

fill(p95_line, p90_line, color=show_fill ? color.new(color_bear, 75) : na, title="Extreme Overbought")
fill(p90_line, p75_line, color=show_fill ? color.new(color_bear, 88) : na, title="Overbought")
fill(p75_line, p50_line, color=show_fill ? color.new(color_bear, 95) : na, title="Upper")
fill(p50_line, p25_line, color=show_fill ? color.new(color_bull, 95) : na, title="Lower")
fill(p25_line, p10_line, color=show_fill ? color.new(color_bull, 88) : na, title="Oversold")
fill(p10_line, p5_line, color=show_fill ? color.new(color_bull, 75) : na, title="Extreme Oversold")

hline(0, "0", color=color.new(color.gray, 80), linestyle=hline.style_dotted)
hline(100, "100", color=color.new(color.gray, 80), linestyle=hline.style_dotted)
hline(50, "50", color=color.new(color.gray, 90), linestyle=hline.style_dotted)

// ────────────────────────────────────────
// SIGNAL DETECTION
// ────────────────────────────────────────

// Percentile confirmation conditions (NA-safe: fallback to Z-only when na)
pct_allows_buy = not enable_percentile_confirm or na(rsi_p5) or (rsi <= rsi_p5)
pct_allows_sell = not enable_percentile_confirm or na(rsi_p95) or (rsi >= rsi_p95)
// [div_lookback] indexed variants for divergence
pct_allows_buy_div = not enable_percentile_confirm or na(rsi_p5[div_lookback]) or (rsi[div_lookback] <= rsi_p5[div_lookback])
pct_allows_sell_div = not enable_percentile_confirm or na(rsi_p95[div_lookback]) or (rsi[div_lookback] >= rsi_p95[div_lookback])

raw_extreme_oversold = ta.crossunder(rsi_zscore, -2)
raw_extreme_overbought = ta.crossover(rsi_zscore, 2)
raw_normal_oversold = ta.crossunder(rsi_zscore, -normal_threshold) and not raw_extreme_oversold
raw_normal_overbought = ta.crossover(rsi_zscore, normal_threshold) and not raw_extreme_overbought

extreme_oversold = raw_extreme_oversold and (not enable_trend_protection or trend_allows_buy) and pct_allows_buy
extreme_overbought = raw_extreme_overbought and (not enable_trend_protection or trend_allows_sell) and pct_allows_sell
normal_oversold = enable_trend_protection ? (raw_normal_oversold and trend_allows_buy) : raw_normal_oversold
normal_overbought = enable_trend_protection ? (raw_normal_overbought and trend_allows_sell) : raw_normal_overbought

// ────────────────────────────────────────
// SIGNAL COOLDOWN
// ────────────────────────────────────────

var int last_mtf_buy_bar = na
var int last_mtf_sell_bar = na
var int last_div_buy_bar = na
var int last_div_sell_bar = na
var int last_ext_buy_bar = na
var int last_ext_sell_bar = na
var int last_norm_buy_bar = na
var int last_norm_sell_bar = na
var int last_buy_level = 0
var int last_sell_level = 0

// ────────────────────────────────────────
// CONSOLIDATED SIGNALS
// ────────────────────────────────────────

bool in_extreme_oversold = rsi_zscore < -2
bool in_extreme_overbought = rsi_zscore > 2

float zscore_at_div = rsi_stdev[div_lookback] != 0 ? (rsi[div_lookback] - rsi_mean[div_lookback]) / rsi_stdev[div_lookback] : 0
bool was_extreme_oversold = (zscore_at_div < -2) and pct_allows_buy_div
bool was_extreme_overbought = (zscore_at_div > 2) and pct_allows_sell_div

bool raw_sig_buy_mtf = enable_mtf and oversold_resonance and extreme_oversold
bool raw_sig_buy_div = enable_divergence and bullish_divergence and was_extreme_oversold and not raw_sig_buy_mtf
bool raw_sig_buy_extreme = extreme_oversold and not raw_sig_buy_mtf and not raw_sig_buy_div
bool raw_sig_buy_normal = normal_oversold and not raw_sig_buy_mtf and not raw_sig_buy_div and not raw_sig_buy_extreme

bool raw_sig_sell_mtf = enable_mtf and overbought_resonance and extreme_overbought
bool raw_sig_sell_div = enable_divergence and bearish_divergence and was_extreme_overbought and not raw_sig_sell_mtf
bool raw_sig_sell_extreme = extreme_overbought and not raw_sig_sell_mtf and not raw_sig_sell_div
bool raw_sig_sell_normal = normal_overbought and not raw_sig_sell_mtf and not raw_sig_sell_div and not raw_sig_sell_extreme

int pending_buy_level = raw_sig_buy_mtf ? 4 : raw_sig_buy_div ? 3 : raw_sig_buy_extreme ? 2 : raw_sig_buy_normal ? 1 : 0
bool buy_upgrade_exempt = pending_buy_level > last_buy_level

int pending_sell_level = raw_sig_sell_mtf ? 4 : raw_sig_sell_div ? 3 : raw_sig_sell_extreme ? 2 : raw_sig_sell_normal ? 1 : 0
bool sell_upgrade_exempt = pending_sell_level > last_sell_level

int cooldown_mtf = 1
int cooldown_div = 1
int cooldown_ext = 1
int cooldown_norm = cooldown_bars

bool sig_buy_mtf = enable_signal_cooldown ? (raw_sig_buy_mtf and (buy_upgrade_exempt or na(last_mtf_buy_bar) or bar_index - last_mtf_buy_bar >= cooldown_mtf)) : raw_sig_buy_mtf
bool sig_buy_div = enable_signal_cooldown ? (raw_sig_buy_div and (buy_upgrade_exempt or na(last_div_buy_bar) or bar_index - last_div_buy_bar >= cooldown_div)) : raw_sig_buy_div
bool sig_buy_extreme = enable_signal_cooldown ? (raw_sig_buy_extreme and (buy_upgrade_exempt or na(last_ext_buy_bar) or bar_index - last_ext_buy_bar >= cooldown_ext)) : raw_sig_buy_extreme
bool sig_buy_normal = enable_signal_cooldown ? (raw_sig_buy_normal and (buy_upgrade_exempt or na(last_norm_buy_bar) or bar_index - last_norm_buy_bar >= cooldown_norm)) : raw_sig_buy_normal

bool sig_sell_mtf = enable_signal_cooldown ? (raw_sig_sell_mtf and (sell_upgrade_exempt or na(last_mtf_sell_bar) or bar_index - last_mtf_sell_bar >= cooldown_mtf)) : raw_sig_sell_mtf
bool sig_sell_div = enable_signal_cooldown ? (raw_sig_sell_div and (sell_upgrade_exempt or na(last_div_sell_bar) or bar_index - last_div_sell_bar >= cooldown_div)) : raw_sig_sell_div
bool sig_sell_extreme = enable_signal_cooldown ? (raw_sig_sell_extreme and (sell_upgrade_exempt or na(last_ext_sell_bar) or bar_index - last_ext_sell_bar >= cooldown_ext)) : raw_sig_sell_extreme
bool sig_sell_normal = enable_signal_cooldown ? (raw_sig_sell_normal and (sell_upgrade_exempt or na(last_norm_sell_bar) or bar_index - last_norm_sell_bar >= cooldown_norm)) : raw_sig_sell_normal

if sig_buy_mtf
    last_mtf_buy_bar := bar_index
    last_buy_level := 4
if sig_buy_div
    last_div_buy_bar := bar_index
    last_buy_level := 3
if sig_buy_extreme
    last_ext_buy_bar := bar_index
    last_buy_level := 2
if sig_buy_normal
    last_norm_buy_bar := bar_index
    last_buy_level := 1

if sig_sell_mtf
    last_mtf_sell_bar := bar_index
    last_sell_level := 4
if sig_sell_div
    last_div_sell_bar := bar_index
    last_sell_level := 3
if sig_sell_extreme
    last_ext_sell_bar := bar_index
    last_sell_level := 2
if sig_sell_normal
    last_norm_sell_bar := bar_index
    last_sell_level := 1

bool sig_div_bull_only = enable_divergence and bullish_divergence and not was_extreme_oversold
bool sig_div_bear_only = enable_divergence and bearish_divergence and not was_extreme_overbought

// 普通信号被 Smart 模式隐藏的状态
bool normal_buy_hidden = sig_buy_normal and not show_normal_signals
bool normal_sell_hidden = sig_sell_normal and not show_normal_signals
string hide_reason = weekly_extreme_bearish ? "周线极端↓" : weekly_extreme_bullish ? "周线极端↑" : ""

// 普通超卖/超买区域持续状态（非信号触发时刻）
bool in_normal_oversold = rsi_zscore < -normal_threshold and rsi_zscore >= -2
bool in_normal_overbought = rsi_zscore > normal_threshold and rsi_zscore <= 2

// ────────────────────────────────────────
// SIGNAL QUALITY SCORING
// ────────────────────────────────────────

f_buy_quality() =>
    score = 0
    if rsi_zscore < -2
        score := 50
    if rsi_zscore < -2.5
        score += 20
    else if rsi_zscore < -2
        score += 10
    if bullish_divergence or oversold_resonance
        score += 25
    // v6.9: RSI 拐点确认 - 极端区形成底部拐点
    if confirmation_buy
        score += 10
    if weekly_uptrend
        score += 15
    if enable_volume_scoring and volume_surge
        score += 10
    if weekly_extreme_bearish
        score -= 20
    if enable_volume_scoring and volume_low
        score -= 10
    if not health_sample_coverage or not health_distribution_spread or not health_stat_valid
        score -= 15
    // v6.9: ADX 趋势惩罚 - 强下跌趋势中抄底减分
    if adx_is_trending and adx_trend_down
        score -= 10
    math.max(score, 0)

f_sell_quality() =>
    score = 0
    if rsi_zscore > 2
        score := 50
    if rsi_zscore > 2.5
        score += 20
    else if rsi_zscore > 2
        score += 10
    if bearish_divergence or overbought_resonance
        score += 25
    // v6.9: RSI 拐点确认 - 极端区形成顶部拐点
    if confirmation_sell
        score += 10
    if weekly_downtrend
        score += 15
    if enable_volume_scoring and volume_surge
        score += 10
    if weekly_extreme_bullish
        score -= 20
    if enable_volume_scoring and volume_low
        score -= 10
    if not health_sample_coverage or not health_distribution_spread or not health_stat_valid
        score -= 15
    // v6.9: ADX 趋势惩罚 - 强上涨趋势中做空减分
    if adx_is_trending and adx_trend_up
        score -= 10
    math.max(score, 0)

current_buy_quality = f_buy_quality()
current_sell_quality = f_sell_quality()

f_quality_grade(_score) =>
    _score >= 80 ? "A" : _score >= 60 ? "B" : _score >= 40 ? "C" : "D"

f_sig_emoji(_sig) =>
    _sig == 1 ? "🌟" : _sig == 2 ? "💎" : _sig == 3 ? "🔥" : "⬆️"

f_dir_color(_dir, _bull, _bear) =>
    _dir == 1 ? _bull : _bear

buy_quality_grade = f_quality_grade(current_buy_quality)
sell_quality_grade = f_quality_grade(current_sell_quality)

// ────────────────────────────────────────
// ATR RISK CALCULATION
// ────────────────────────────────────────

atr_14 = ta.atr(14)
atr_pct = atr_14 / close * 100

// 止损倍数根据信号质量等级调整
f_sl_multiplier(_grade) =>
    _grade == "A" ? 2.5 : _grade == "B" ? 2.0 : _grade == "C" ? 1.5 : 1.2

// 计算止损/止盈（多头）
buy_sl_mult = f_sl_multiplier(buy_quality_grade)
buy_sl_distance = atr_14 * buy_sl_mult
buy_sl_price = close - buy_sl_distance
buy_sl_pct = buy_sl_distance / close * 100
buy_tp_distance = buy_sl_distance * alert_rr_ratio
buy_tp_price = close + buy_tp_distance
buy_tp_pct = buy_tp_distance / close * 100

// 计算止损/止盈（空头/退出多头）
sell_sl_mult = f_sl_multiplier(sell_quality_grade)
sell_sl_distance = atr_14 * sell_sl_mult
sell_sl_price = close + sell_sl_distance  // 空头止损在上方
sell_sl_pct = sell_sl_distance / close * 100
sell_tp_distance = sell_sl_distance * alert_rr_ratio
sell_tp_price = close - sell_tp_distance
sell_tp_pct = sell_tp_distance / close * 100

active_signal_grade = sig_buy_mtf or sig_buy_div or sig_buy_extreme or sig_buy_normal ? buy_quality_grade :
                      sig_sell_mtf or sig_sell_div or sig_sell_extreme or sig_sell_normal ? sell_quality_grade :
                      normal_buy_hidden ? buy_quality_grade :
                      normal_sell_hidden ? sell_quality_grade :
                      in_extreme_oversold ? buy_quality_grade :
                      in_extreme_overbought ? sell_quality_grade :
                      in_normal_oversold ? buy_quality_grade :
                      in_normal_overbought ? sell_quality_grade : ""

// ────────────────────────────────────────
// STATISTICS CALCULATION
// ────────────────────────────────────────

has_buy_signal = sig_buy_mtf or sig_buy_div or sig_buy_extreme or sig_buy_normal
has_sell_signal = sig_sell_mtf or sig_sell_div or sig_sell_extreme or sig_sell_normal

if enable_stats and bar_index > stats_forward_bars
    forward_return_long = (close - close[stats_forward_bars]) / close[stats_forward_bars] * 100
    // Sell统计口径：Long Exit = 价格下跌为正（卖出正确），Short Entry = 做空收益
    // Long Exit: 信号后价格下跌 = 卖出决策正确，用同样的公式但从多头退出角度解读
    // Short Entry: 原有逻辑，做空收益
    forward_return_short = (close[stats_forward_bars] - close) / close[stats_forward_bars] * 100

    f_update_stats_bucket(signal_type_stats, f_signal_type_bucket_index(true, STATS_SIGNAL_MTF), sig_buy_mtf[stats_forward_bars], forward_return_long)
    f_update_stats_bucket(signal_type_stats, f_signal_type_bucket_index(false, STATS_SIGNAL_MTF), sig_sell_mtf[stats_forward_bars], forward_return_short)
    f_update_stats_bucket(signal_type_stats, f_signal_type_bucket_index(true, STATS_SIGNAL_DIV), sig_buy_div[stats_forward_bars], forward_return_long)
    f_update_stats_bucket(signal_type_stats, f_signal_type_bucket_index(false, STATS_SIGNAL_DIV), sig_sell_div[stats_forward_bars], forward_return_short)
    f_update_stats_bucket(signal_type_stats, f_signal_type_bucket_index(true, STATS_SIGNAL_EXT), sig_buy_extreme[stats_forward_bars], forward_return_long)
    f_update_stats_bucket(signal_type_stats, f_signal_type_bucket_index(false, STATS_SIGNAL_EXT), sig_sell_extreme[stats_forward_bars], forward_return_short)
    f_update_stats_bucket(signal_type_stats, f_signal_type_bucket_index(true, STATS_SIGNAL_NORM), sig_buy_normal[stats_forward_bars], forward_return_long)
    f_update_stats_bucket(signal_type_stats, f_signal_type_bucket_index(false, STATS_SIGNAL_NORM), sig_sell_normal[stats_forward_bars], forward_return_short)

    past_buy_signal = has_buy_signal[stats_forward_bars]
    past_buy_grade = buy_quality_grade[stats_forward_bars]
    if past_buy_signal
        f_update_stats_bucket(grade_stats, f_grade_bucket_index(true, past_buy_grade), true, forward_return_long)

    past_sell_signal = has_sell_signal[stats_forward_bars]
    past_sell_grade = sell_quality_grade[stats_forward_bars]
    if past_sell_signal
        f_update_stats_bucket(grade_stats, f_grade_bucket_index(false, past_sell_grade), true, forward_return_short)

    f_update_stats_bucket(ranking_stats, f_ranking_bucket_index(true, STATS_SIGNAL_MTF, past_buy_grade), sig_buy_mtf[stats_forward_bars], forward_return_long)
    f_update_stats_bucket(ranking_stats, f_ranking_bucket_index(false, STATS_SIGNAL_MTF, past_sell_grade), sig_sell_mtf[stats_forward_bars], forward_return_short)
    f_update_stats_bucket(ranking_stats, f_ranking_bucket_index(true, STATS_SIGNAL_DIV, past_buy_grade), sig_buy_div[stats_forward_bars], forward_return_long)
    f_update_stats_bucket(ranking_stats, f_ranking_bucket_index(false, STATS_SIGNAL_DIV, past_sell_grade), sig_sell_div[stats_forward_bars], forward_return_short)
    f_update_stats_bucket(ranking_stats, f_ranking_bucket_index(true, STATS_SIGNAL_EXT, past_buy_grade), sig_buy_extreme[stats_forward_bars], forward_return_long)
    f_update_stats_bucket(ranking_stats, f_ranking_bucket_index(false, STATS_SIGNAL_EXT, past_sell_grade), sig_sell_extreme[stats_forward_bars], forward_return_short)
    f_update_stats_bucket(ranking_stats, f_ranking_bucket_index(true, STATS_SIGNAL_NORM, past_buy_grade), sig_buy_normal[stats_forward_bars], forward_return_long)
    f_update_stats_bucket(ranking_stats, f_ranking_bucket_index(false, STATS_SIGNAL_NORM, past_sell_grade), sig_sell_normal[stats_forward_bars], forward_return_short)

// ────────────────────────────────────────
// STATISTICS-DRIVEN FILTER
// ────────────────────────────────────────

// 获取当前信号对应的统计数据
f_get_signal_stats(_is_buy, _is_mtf, _is_div, _is_ext, _grade) =>
    array.get(ranking_stats, f_ranking_bucket_index(_is_buy, f_signal_kind_index(_is_mtf, _is_div, _is_ext), _grade))

f_get_type_stats(_is_buy, _is_mtf, _is_div, _is_ext) =>
    array.get(signal_type_stats, f_signal_type_bucket_index(_is_buy, f_signal_kind_index(_is_mtf, _is_div, _is_ext)))

f_get_grade_stats(_is_buy, _grade) =>
    array.get(grade_stats, f_grade_bucket_index(_is_buy, _grade))

f_get_filter_stats(_is_buy, _is_mtf, _is_div, _is_ext, _grade) =>
    if stats_mode == "Signal Type"
        f_get_type_stats(_is_buy, _is_mtf, _is_div, _is_ext)
    else if stats_mode == "Grade"
        f_get_grade_stats(_is_buy, _grade)
    else
        f_get_signal_stats(_is_buy, _is_mtf, _is_div, _is_ext, _grade)

f_get_signal_type_label(_is_mtf, _is_div, _is_ext) =>
    _is_mtf ? "MTF" : _is_div ? "DIV" : _is_ext ? "EXT" : "NORM"

f_get_filter_source_label(_is_mtf, _is_div, _is_ext, _grade) =>
    _type_label = f_get_signal_type_label(_is_mtf, _is_div, _is_ext)
    stats_mode == "Signal Type" ? str.format("TYPE:{0}", _type_label) :
     stats_mode == "Grade" ? str.format("GRADE[{0}]", _grade) :
     str.format("{0}[{1}]", _type_label, _grade)

// 检查信号是否通过统计过滤
f_passes_stats_filter(_stats) =>
    if not enable_stats_filter or not enable_stats
        true
    else
        _count = _stats.count
        _adj_wr = _stats.get_adjusted_winrate()
        _has_enough_samples = _count >= stats_min_samples
        _has_good_winrate = not na(_adj_wr) and _adj_wr >= stats_min_winrate
        _has_enough_samples and _has_good_winrate

// 根据 stats_mode 选择实际用于生产过滤的统计桶
buy_mtf_stats = f_get_filter_stats(true, true, false, false, buy_quality_grade)
buy_div_stats = f_get_filter_stats(true, false, true, false, buy_quality_grade)
buy_ext_stats = f_get_filter_stats(true, false, false, true, buy_quality_grade)
buy_norm_stats = f_get_filter_stats(true, false, false, false, buy_quality_grade)

sell_mtf_stats = f_get_filter_stats(false, true, false, false, sell_quality_grade)
sell_div_stats = f_get_filter_stats(false, false, true, false, sell_quality_grade)
sell_ext_stats = f_get_filter_stats(false, false, false, true, sell_quality_grade)
sell_norm_stats = f_get_filter_stats(false, false, false, false, sell_quality_grade)

// 过滤结果
filter_buy_mtf = f_passes_stats_filter(buy_mtf_stats)
filter_buy_div = f_passes_stats_filter(buy_div_stats)
filter_buy_ext = f_passes_stats_filter(buy_ext_stats)
filter_buy_norm = f_passes_stats_filter(buy_norm_stats)

filter_sell_mtf = f_passes_stats_filter(sell_mtf_stats)
filter_sell_div = f_passes_stats_filter(sell_div_stats)
filter_sell_ext = f_passes_stats_filter(sell_ext_stats)
filter_sell_norm = f_passes_stats_filter(sell_norm_stats)

// 根据过滤模式决定显示的信号
// Hard: 只显示通过的信号
// Soft: 所有信号都显示，但通过的正常显示，未通过的降级显示
// Alert Only: 所有信号正常显示，仅Alert过滤
show_buy_mtf = stats_filter_mode == "Hard" ? (sig_buy_mtf and filter_buy_mtf) : sig_buy_mtf
show_buy_div = stats_filter_mode == "Hard" ? (sig_buy_div and filter_buy_div) : sig_buy_div
show_buy_ext = stats_filter_mode == "Hard" ? (sig_buy_extreme and filter_buy_ext) : sig_buy_extreme
show_buy_norm = stats_filter_mode == "Hard" ? (sig_buy_normal and filter_buy_norm) : sig_buy_normal

show_sell_mtf = stats_filter_mode == "Hard" ? (sig_sell_mtf and filter_sell_mtf) : sig_sell_mtf
show_sell_div = stats_filter_mode == "Hard" ? (sig_sell_div and filter_sell_div) : sig_sell_div
show_sell_ext = stats_filter_mode == "Hard" ? (sig_sell_extreme and filter_sell_ext) : sig_sell_extreme
show_sell_norm = stats_filter_mode == "Hard" ? (sig_sell_normal and filter_sell_norm) : sig_sell_normal

// Soft模式：降级显示（未通过过滤的信号）
soft_degraded_buy_mtf = stats_filter_mode == "Soft" and sig_buy_mtf and not filter_buy_mtf
soft_degraded_buy_div = stats_filter_mode == "Soft" and sig_buy_div and not filter_buy_div
soft_degraded_buy_ext = stats_filter_mode == "Soft" and sig_buy_extreme and not filter_buy_ext
soft_degraded_buy_norm = stats_filter_mode == "Soft" and sig_buy_normal and not filter_buy_norm

soft_degraded_sell_mtf = stats_filter_mode == "Soft" and sig_sell_mtf and not filter_sell_mtf
soft_degraded_sell_div = stats_filter_mode == "Soft" and sig_sell_div and not filter_sell_div
soft_degraded_sell_ext = stats_filter_mode == "Soft" and sig_sell_extreme and not filter_sell_ext
soft_degraded_sell_norm = stats_filter_mode == "Soft" and sig_sell_normal and not filter_sell_norm

// Alert过滤：所有模式都应用
alert_buy_mtf = sig_buy_mtf and filter_buy_mtf
alert_buy_div = sig_buy_div and filter_buy_div
alert_buy_ext = sig_buy_extreme and filter_buy_ext
alert_buy_norm = sig_buy_normal and filter_buy_norm

alert_sell_mtf = sig_sell_mtf and filter_sell_mtf
alert_sell_div = sig_sell_div and filter_sell_div
alert_sell_ext = sig_sell_extreme and filter_sell_ext
alert_sell_norm = sig_sell_normal and filter_sell_norm

// 当前信号的过滤状态（用于Dashboard显示）
current_signal_passes_filter = sig_buy_mtf ? filter_buy_mtf :
                               sig_buy_div ? filter_buy_div :
                               sig_buy_extreme ? filter_buy_ext :
                               sig_buy_normal ? filter_buy_norm :
                               sig_sell_mtf ? filter_sell_mtf :
                               sig_sell_div ? filter_sell_div :
                               sig_sell_extreme ? filter_sell_ext :
                               sig_sell_normal ? filter_sell_norm : true

// ────────────────────────────────────────
// 信号隐藏状态检测（用于统一显示）
// ────────────────────────────────────────

// 极端信号被趋势保护隐藏
bool extreme_buy_hidden = enable_trend_protection and raw_extreme_oversold and not trend_allows_buy
bool extreme_sell_hidden = enable_trend_protection and raw_extreme_overbought and not trend_allows_sell

// Hard 模式被统计过滤隐藏
bool hard_hidden_buy = stats_filter_mode == "Hard" and (
    (sig_buy_mtf and not filter_buy_mtf) or
    (sig_buy_div and not filter_buy_div) or
    (sig_buy_extreme and not filter_buy_ext) or
    (sig_buy_normal and not filter_buy_norm))
bool hard_hidden_sell = stats_filter_mode == "Hard" and (
    (sig_sell_mtf and not filter_sell_mtf) or
    (sig_sell_div and not filter_sell_div) or
    (sig_sell_extreme and not filter_sell_ext) or
    (sig_sell_normal and not filter_sell_norm))

// 普通区域被 Smart 隐藏
bool normal_zone_hidden = (in_normal_oversold or in_normal_overbought) and not show_normal_signals

// 是否为信号触发时刻（包括被隐藏的）
bool is_signal_trigger = sig_buy_mtf or sig_buy_div or sig_buy_extreme or sig_buy_normal or
                         sig_sell_mtf or sig_sell_div or sig_sell_extreme or sig_sell_normal or
                         extreme_buy_hidden or extreme_sell_hidden

// 是否被隐藏（任何原因）
bool is_any_hidden = normal_buy_hidden or normal_sell_hidden or 
                     extreme_buy_hidden or extreme_sell_hidden or
                     hard_hidden_buy or hard_hidden_sell or 
                     normal_zone_hidden

// ────────────────────────────────────────
// SIGNAL DISPLAY
// ────────────────────────────────────────

// 正常显示的信号（通过过滤或非Hard模式且通过）
plotshape(show_buy_mtf and not soft_degraded_buy_mtf, title="🌟 MTF+极端超卖", style=shape.labelup, location=location.bottom, color=#00E676, size=size.normal, text="🌟", textcolor=color.white)
plotshape(show_buy_div and not soft_degraded_buy_div, title="💎 背离+极端超卖", style=shape.labelup, location=location.bottom, color=#00BCD4, size=size.normal, text="💎", textcolor=color.white)
plotshape(show_buy_ext and not soft_degraded_buy_ext, title="🔥 极端超卖", style=shape.triangleup, location=location.bottom, color=color_bull, size=size.small, text="🔥")
plotshape(show_normal_signals and show_buy_norm and not soft_degraded_buy_norm, title="⬆️ 普通超卖", style=shape.circle, location=location.bottom, color=color.new(color_bull, 30), size=size.tiny, text="⬆️")

// 卖出信号 (顶部)
plotshape(show_sell_mtf and not soft_degraded_sell_mtf, title="🌟 MTF+极端超买", style=shape.labeldown, location=location.top, color=#FF5252, size=size.normal, text="🌟", textcolor=color.white)
plotshape(show_sell_div and not soft_degraded_sell_div, title="💎 背离+极端超买", style=shape.labeldown, location=location.top, color=#FF9800, size=size.normal, text="💎", textcolor=color.white)
plotshape(show_sell_ext and not soft_degraded_sell_ext, title="❄️ 极端超买", style=shape.triangledown, location=location.top, color=color_bear, size=size.small, text="❄️")
plotshape(show_normal_signals and show_sell_norm and not soft_degraded_sell_norm, title="⬇️ 普通超买", style=shape.circle, location=location.top, color=color.new(color_bear, 30), size=size.tiny, text="⬇️")

// Soft模式降级显示（半透明、更小）
plotshape(soft_degraded_buy_mtf, title="🌟 MTF+极端超卖(降级)", style=shape.labelup, location=location.bottom, color=color.new(#00E676, 70), size=size.tiny, text="🌟", textcolor=color.new(color.white, 50))
plotshape(soft_degraded_buy_div, title="💎 背离+极端超卖(降级)", style=shape.labelup, location=location.bottom, color=color.new(#00BCD4, 70), size=size.tiny, text="💎", textcolor=color.new(color.white, 50))
plotshape(soft_degraded_buy_ext, title="🔥 极端超卖(降级)", style=shape.triangleup, location=location.bottom, color=color.new(color_bull, 70), size=size.tiny, text="🔥")
plotshape(show_normal_signals and soft_degraded_buy_norm, title="⬆️ 普通超卖(降级)", style=shape.circle, location=location.bottom, color=color.new(color_bull, 80), size=size.tiny, text="⬆️")

plotshape(soft_degraded_sell_mtf, title="🌟 MTF+极端超买(降级)", style=shape.labeldown, location=location.top, color=color.new(#FF5252, 70), size=size.tiny, text="🌟", textcolor=color.new(color.white, 50))
plotshape(soft_degraded_sell_div, title="💎 背离+极端超买(降级)", style=shape.labeldown, location=location.top, color=color.new(#FF9800, 70), size=size.tiny, text="💎", textcolor=color.new(color.white, 50))
plotshape(soft_degraded_sell_ext, title="❄️ 极端超买(降级)", style=shape.triangledown, location=location.top, color=color.new(color_bear, 70), size=size.tiny, text="❄️")
plotshape(show_normal_signals and soft_degraded_sell_norm, title="⬇️ 普通超买(降级)", style=shape.circle, location=location.top, color=color.new(color_bear, 80), size=size.tiny, text="⬇️")

// 纯背离信号
plotshape(sig_div_bull_only, title="↗️ 看涨背离", style=shape.circle, location=location.bottom, color=#00BCD4, size=size.tiny, text="↗️")
plotshape(sig_div_bear_only, title="↘️ 看跌背离", style=shape.circle, location=location.top, color=#FF9800, size=size.tiny, text="↘️")

// 双层背景：普通区域(浅) + 极端区域(深)
bgcolor(rsi_zscore < -normal_threshold ? color.new(color_bull, 93) : rsi_zscore > normal_threshold ? color.new(color_bear, 93) : na, title="Normal Zone")
bgcolor(rsi_zscore < -2 ? color.new(color_bull, 85) : rsi_zscore > 2 ? color.new(color_bear, 85) : na, title="Extreme Zone")

// ────────────────────────────────────────
// 通用信号显示逻辑（Mobile/Full 共用）
// ────────────────────────────────────────

// 信号方向：1=买入, -1=卖出, 0=无
bool is_buy_signal = sig_buy_mtf or sig_buy_div or sig_buy_extreme or sig_buy_normal or normal_buy_hidden or extreme_buy_hidden or hard_hidden_buy or sig_div_bull_only or in_extreme_oversold or in_normal_oversold
bool is_sell_signal = sig_sell_mtf or sig_sell_div or sig_sell_extreme or sig_sell_normal or normal_sell_hidden or extreme_sell_hidden or hard_hidden_sell or sig_div_bear_only or in_extreme_overbought or in_normal_overbought
signal_direction = is_buy_signal ? 1 : is_sell_signal ? -1 : 0

// 信号类型文本（按优先级）
string signal_type_text = switch
    sig_buy_mtf or sig_sell_mtf => "🌟"
    sig_buy_div or sig_sell_div => "💎"
    sig_buy_extreme or extreme_buy_hidden => "🔥"
    sig_sell_extreme or extreme_sell_hidden => "❄️"
    sig_buy_normal or normal_buy_hidden => "⬆️"
    sig_sell_normal or normal_sell_hidden => "⬇️"
    sig_div_bull_only => "↗️"
    sig_div_bear_only => "↘️"
    in_extreme_oversold => "🔥持续"
    in_extreme_overbought => "❄️持续"
    in_normal_oversold => "超卖区"
    in_normal_overbought => "超买区"
    => "⚪"

// 信号评级
signal_grade_text = signal_direction == 1 ? buy_quality_grade : signal_direction == -1 ? sell_quality_grade : ""

// 当前信号是否被隐藏
bool buy_is_hidden = normal_buy_hidden or extreme_buy_hidden or hard_hidden_buy or (in_normal_oversold and not show_normal_signals)
bool sell_is_hidden = normal_sell_hidden or extreme_sell_hidden or hard_hidden_sell or (in_normal_overbought and not show_normal_signals)
current_is_hidden = (signal_direction == 1 and buy_is_hidden) or (signal_direction == -1 and sell_is_hidden)

// 信号标记（✓/⚠️/🚫/空）
signal_mark_text = current_is_hidden ? "🚫" : is_signal_trigger and enable_stats_filter ? (current_signal_passes_filter ? "✓" : "⚠️") : ""

// 完整信号显示文本
signal_full_display = signal_type_text + (signal_grade_text != "" ? "[" + signal_grade_text + "]" : "") + signal_mark_text

// 信号颜色
signal_full_color = current_is_hidden ? color.new(color.gray, 40) : signal_direction == 1 ? color_bull : signal_direction == -1 ? color_bear : color.gray

// 状态文本（统一使用 normal_threshold）
status_text_full = rsi_zscore < -2 ? "🟢 EXTREME OVERSOLD" : rsi_zscore < -normal_threshold ? "🟡 OVERSOLD" : rsi_zscore > 2 ? "🔴 EXTREME OVERBOUGHT" : rsi_zscore > normal_threshold ? "🟠 OVERBOUGHT" : "⚪ NEUTRAL"

status_text_mobile = rsi_zscore < -2 ? "🟢极卖" : rsi_zscore < -normal_threshold ? "🟡超卖" : rsi_zscore > 2 ? "🔴极买" : rsi_zscore > normal_threshold ? "🟠超买" : "⚪中性"

status_display_color = rsi_zscore < -normal_threshold ? color_bull : rsi_zscore > normal_threshold ? color_bear : color.gray

// ────────────────────────────────────────
// DASHBOARD
// ────────────────────────────────────────

f_status_text(_status) =>
    _status == 1 ? "🟢" : _status == -1 ? "🔴" : "⚪"

f_harness_gate_snapshot() =>
    string _source = "Idle"
    int _count = 0
    float _avg = 0.0
    float _adj = 0.0
    bool _use_buy = harness_trade_side == "Long Only" ? true : harness_trade_side == "Short Only" ? false : signal_direction != -1
    SignalStats _stats = SignalStats.new()

    if _use_buy
        if sig_buy_mtf
            _stats := f_get_filter_stats(true, true, false, false, buy_quality_grade)
            _source := f_get_filter_source_label(true, false, false, buy_quality_grade)
        else if sig_buy_div
            _stats := f_get_filter_stats(true, false, true, false, buy_quality_grade)
            _source := f_get_filter_source_label(false, true, false, buy_quality_grade)
        else if sig_buy_extreme
            _stats := f_get_filter_stats(true, false, false, true, buy_quality_grade)
            _source := f_get_filter_source_label(false, false, true, buy_quality_grade)
        else if sig_buy_normal
            _stats := f_get_filter_stats(true, false, false, false, buy_quality_grade)
            _source := f_get_filter_source_label(false, false, false, buy_quality_grade)
    else
        if sig_sell_mtf
            _stats := f_get_filter_stats(false, true, false, false, sell_quality_grade)
            _source := f_get_filter_source_label(true, false, false, sell_quality_grade)
        else if sig_sell_div
            _stats := f_get_filter_stats(false, false, true, false, sell_quality_grade)
            _source := f_get_filter_source_label(false, true, false, sell_quality_grade)
        else if sig_sell_extreme
            _stats := f_get_filter_stats(false, false, false, true, sell_quality_grade)
            _source := f_get_filter_source_label(false, false, true, sell_quality_grade)
        else if sig_sell_normal
            _stats := f_get_filter_stats(false, false, false, false, sell_quality_grade)
            _source := f_get_filter_source_label(false, false, false, sell_quality_grade)

    if _source != "Idle"
        _count := _stats.count
        _avg := _stats.get_avg()
        _adj := nz(_stats.get_adjusted_winrate(), 0.0)

    [_source, _count, _avg, _adj]

if show_dashboard
    rsi_percentile = 0.0
    if rsi <= rsi_p5
        rsi_percentile := 5.0
    else if rsi <= rsi_p10
        rsi_percentile := 10.0
    else if rsi <= rsi_p25
        rsi_percentile := 25.0
    else if rsi <= rsi_p50
        rsi_percentile := 50.0
    else if rsi <= rsi_p75
        rsi_percentile := 75.0
    else if rsi <= rsi_p90
        rsi_percentile := 90.0
    else if rsi <= rsi_p95
        rsi_percentile := 95.0
    else
        rsi_percentile := 99.0

    txt_size_title = dashboard_size == "Tiny" ? size.tiny : dashboard_size == "Small" ? size.small : dashboard_size == "Normal" ? size.normal : size.large
    txt_size_body = dashboard_size == "Tiny" ? size.tiny : dashboard_size == "Small" ? size.tiny : dashboard_size == "Normal" ? size.small : size.normal

    div_text = bullish_divergence ? "🟢 BULL" : bearish_divergence ? "🔴 BEAR" : "—"
    div_color = bullish_divergence ? #00BCD4 : bearish_divergence ? #FF9800 : color.gray

    resonance_text = oversold_resonance ? str.format("🟢 {0}/{1}", oversold_count, valid_tf_count) :
                     overbought_resonance ? str.format("🔴 {0}/{1}", overbought_count, valid_tf_count) :
                     str.format("⚪ {0}/{1}", math.max(oversold_count, overbought_count), valid_tf_count)
    resonance_color = oversold_resonance ? color_bull : overbought_resonance ? color_bear : color.gray

    mobile_rows = 3
    full_rows = 11 + (enable_mtf ? 2 : 0) + (enable_divergence ? 1 : 0) + (enable_stats ? 9 : 0)
    total_rows = dashboard_mode == "Mobile" ? mobile_rows : full_rows

    var table dashboard = table.new(position.top_right, 2, 24,
                                     bgcolor=color.new(#1a1a2e, dashboard_transparency),
                                     border_width=1, border_color=color.new(#4a4a6a, 50))
    
    if barstate.islastconfirmedhistory or barstate.isrealtime
        table.clear(dashboard, 0, 0, 1, 23)
        row = 0

        if dashboard_mode == "Mobile"
            // Row 1: RSI
            table.cell(dashboard, 0, row, "RSI", text_color=color.gray, text_size=txt_size_body, bgcolor=color.new(#2962FF, dashboard_transparency))
            table.cell(dashboard, 1, row, str.tostring(rsi, "#.1"), text_color=color_rsi, text_size=txt_size_body, bgcolor=color.new(#2962FF, dashboard_transparency))
            row += 1

            // Row 2: Signal（使用通用变量）
            table.cell(dashboard, 0, row, "Signal", text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, signal_full_display, text_color=signal_full_color, text_size=txt_size_body)
            row += 1

            // Row 3: Status（纯状态，无评级）
            table.cell(dashboard, 0, row, "Status", text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, status_text_mobile, text_color=status_display_color, text_size=txt_size_body)
            row += 1

        else
            table.cell(dashboard, 0, row, "ADAPTIVE RSI", text_color=color.white, text_size=txt_size_title, bgcolor=color.new(#2962FF, dashboard_transparency))
            table.cell(dashboard, 1, row, str.tostring(rsi, "#.0"), text_color=color_rsi, text_size=txt_size_title, bgcolor=color.new(#2962FF, dashboard_transparency))
            row += 1

            zscore_approx_pct = f_zscore_to_percentile(rsi_zscore)
            zscore_display = str.format("{0,number,#.2}σ (≈P{1,number,#})", rsi_zscore, zscore_approx_pct)
            table.cell(dashboard, 0, row, "Z-Score", text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, zscore_display, text_color=status_display_color, text_size=txt_size_body)
            row += 1

            pct_zscore_range = f_percentile_zscore_range(rsi_percentile)
            percentile_display = str.format("P{0,number,#}{1}", rsi_percentile, pct_zscore_range)
            table.cell(dashboard, 0, row, "Percentile", text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, percentile_display, text_color=status_display_color, text_size=txt_size_body)
            row += 1

            // Signal 行（使用通用变量，与 Mobile 一致）
            table.cell(dashboard, 0, row, "Signal", text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, signal_full_display, text_color=signal_full_color, text_size=txt_size_body)
            row += 1

            // Status 行（纯状态，无评级）
            table.cell(dashboard, 0, row, "Status", text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, status_text_full, text_color=status_display_color, text_size=txt_size_body)
            row += 1

            harness_side_display = harness_trade_side == "Long Only" ? "Long" : harness_trade_side == "Short Only" ? "Short" : "Both"
            harness_mode_display = harness_use_production ? "Production" : "Baseline"
            harness_tester_display = harness_trade_side == "Long Only" ? "Read All = Long" : harness_trade_side == "Short Only" ? "Read All = Short" : "Read All = Both"
            [harness_gate_source, harness_gate_count, harness_gate_avg, harness_gate_adj] = f_harness_gate_snapshot()
            harness_gate_display = harness_gate_source == "Idle" ? "Idle" : str.format("{0}({1}) {2,number,+#.1;-#.1}%|{3,number,#}%", harness_gate_source, harness_gate_count, harness_gate_avg, harness_gate_adj)

            table.cell(dashboard, 0, row, "Harness", text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, str.format("{0} | {1}", harness_side_display, harness_mode_display), text_color=color.white, text_size=txt_size_body)
            row += 1

            table.cell(dashboard, 0, row, "Tester", text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, harness_tester_display, text_color=color.white, text_size=txt_size_body)
            row += 1

            table.cell(dashboard, 0, row, "Production Gate", text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, harness_gate_display, text_color=color.white, text_size=txt_size_body)
            row += 1

            weekly_rsi_display = na(weekly_rsi) ? "W.RSI:--" : str.format("W.RSI:{0,number,#}", weekly_rsi)
            vol_display = volume_surge ? "📊↑" : volume_low ? "📊↓" : "📊"
            protection_color = trend_allows_buy and trend_allows_sell ? color.white :
                              trend_allows_buy or trend_allows_sell ? color.yellow : color.red
            table.cell(dashboard, 0, row, str.format("Protection [{0}]", protection_level), text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, str.format("{0} {1} {2}", protection_status, weekly_rsi_display, vol_display), text_color=protection_color, text_size=txt_size_body)
            row += 1

            lookback_mode_display = lookback_mode == "Auto" ? "[Auto]" : "[Custom]"
            spread_indicator = spread_factor > 1.0 ? "↑" : spread_factor < 1.0 ? "↓" : ""
            health_icons = (health_sample_coverage ? "✅" : "⚠️") + (health_distribution_spread ? "✅" : "⚠️") + (health_stat_valid ? "✅" : "⚠️")
            lookback_color = health_sample_coverage and health_distribution_spread and health_stat_valid ? color.white : color.yellow
            table.cell(dashboard, 0, row, str.format("Lookback {0}", lookback_mode_display), text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, str.format("{0}{1}({2}-{3}) {4}", lookback, spread_indicator, lookback_min, lookback_max, health_icons), text_color=lookback_color, text_size=txt_size_body)
            row += 1

            // Normal Signal 行
            normal_mode_display = normal_signal_mode == "Smart" ? "[Smart]" : normal_signal_mode == "On" ? "[On]" : "[Off]"
            normal_status = normal_signal_mode == "Off" ? "—" : show_normal_signals ? str.format("⬆️{0,number,#.2}σ ✓", normal_threshold) : str.format("{0,number,#.2}σ ✗", normal_threshold)
            normal_color = normal_signal_mode == "Off" ? color.gray : show_normal_signals ? color.white : color.new(color.gray, 50)
            table.cell(dashboard, 0, row, str.format("Normal {0}", normal_mode_display), text_color=color.gray, text_size=txt_size_body)
            table.cell(dashboard, 1, row, normal_status, text_color=normal_color, text_size=txt_size_body)
            row += 1

            if dashboard_mode == "Full"
                if enable_mtf
                    table.cell(dashboard, 0, row, str.format("MTF {0}|{1}|{2}", mtf_tf1_display, mtf_tf2_display, mtf_tf3_display), text_color=color.gray, text_size=txt_size_body)
                    table.cell(dashboard, 1, row, str.format("{0}|{1}|{2}", f_status_text(status_tf1), f_status_text(status_tf2), f_status_text(status_tf3)), text_color=color.white, text_size=txt_size_body)
                    row += 1

                    table.cell(dashboard, 0, row, "Resonance", text_color=color.gray, text_size=txt_size_body)
                    table.cell(dashboard, 1, row, resonance_text, text_color=resonance_color, text_size=txt_size_body)
                    row += 1

                if enable_divergence
                    div_mode_display = div_mode == "Auto" ? str.format("[{0}]", active_div_mode) : ""
                    table.cell(dashboard, 0, row, str.format("Divergence {0}", div_mode_display), text_color=color.gray, text_size=txt_size_body)
                    table.cell(dashboard, 1, row, str.format("{0} ({1}/{2})", div_text, div_lookback, div_range), text_color=div_color, text_size=txt_size_body)
                    row += 1

                if enable_stats
                    stats_title = stats_mode == "Ranking" ? "── RANKING ──" : stats_mode == "Grade" ? "── GRADE STATS ──" : "── SIGNAL STATS ──"
                    table.cell(dashboard, 0, row, stats_title, text_color=color.gray, text_size=txt_size_body)
                    table.cell(dashboard, 1, row, str.format("({0}b)", stats_forward_bars), text_color=color.gray, text_size=txt_size_body)
                    row += 1

                    if stats_mode == "Signal Type"
                        for sig_idx = 0 to STATS_SIGNAL_COUNT - 1
                            for dir_idx = 0 to STATS_DIR_COUNT - 1
                                is_buy = dir_idx == STATS_DIR_BUY
                                sig_stats = array.get(signal_type_stats, f_signal_type_bucket_index(is_buy, sig_idx))
                                sig_wr = f_stats_wr_text(sig_stats)
                                table.cell(dashboard, 0, row, str.format("{0}({1}){2}", f_signal_type_dashboard_label(sig_idx, is_buy), sig_stats.count, sig_stats.get_reliability()), text_color=f_signal_type_dashboard_color(sig_idx, is_buy, color_bull, color_bear), text_size=txt_size_body)
                                table.cell(dashboard, 1, row, str.format("{0,number,+#.1;-#.1}%|{1}", sig_stats.get_avg(), sig_wr), text_color=is_buy ? color_bull : color_bear, text_size=txt_size_body)
                                row += 1

                    else if stats_mode == "Grade"
                        for grade_idx = 0 to STATS_GRADE_COUNT - 1
                            for dir_idx = 0 to STATS_DIR_COUNT - 1
                                is_buy = dir_idx == STATS_DIR_BUY
                                grade_label = f_grade_value(grade_idx)
                                grade_bucket = array.get(grade_stats, grade_idx * STATS_DIR_COUNT + dir_idx)
                                grade_display = f_stats_avg_wr_text(grade_bucket)
                                table.cell(dashboard, 0, row, str.format("[{0}]{1}({2}){3}", grade_label, is_buy ? "📈" : "📉", grade_bucket.count, grade_bucket.get_reliability()), text_color=f_grade_dashboard_color(grade_idx), text_size=txt_size_body)
                                table.cell(dashboard, 1, row, grade_display, text_color=is_buy ? color_bull : color_bear, text_size=txt_size_body)
                                row += 1

                    else if stats_mode == "Ranking"
                        var ranking_wr = array.new_float(STATS_RANKING_BUCKETS, 0.0)
                        var ranking_idx = array.new_int(STATS_RANKING_BUCKETS)

                        for i = 0 to STATS_RANKING_BUCKETS - 1
                            rank_stats = array.get(ranking_stats, i)
                            array.set(ranking_wr, i, rank_stats.count >= 5 ? rank_stats.get_adjusted_winrate() : 0)
                            array.set(ranking_idx, i, i)

                        // 创建索引数组用于排序
                        for i = 0 to STATS_RANKING_BUCKETS - 2
                            for j = 0 to STATS_RANKING_BUCKETS - 2 - i
                                idx_j = array.get(ranking_idx, j)
                                idx_j1 = array.get(ranking_idx, j + 1)
                                if array.get(ranking_wr, idx_j) < array.get(ranking_wr, idx_j1)
                                    array.set(ranking_idx, j, idx_j1)
                                    array.set(ranking_idx, j + 1, idx_j)

                        display_count = 0
                        for i = 0 to STATS_RANKING_BUCKETS - 1
                            if display_count >= 8
                                break
                            idx = array.get(ranking_idx, i)
                            wr = array.get(ranking_wr, idx)
                            if wr > 0  // 只显示有数据的
                                rank_stats = array.get(ranking_stats, idx)
                                sig = f_ranking_signal_number(idx)
                                grd = f_grade_value(f_ranking_grade_index(idx))
                                dir = f_ranking_direction_number(idx)
                                ret = rank_stats.get_avg()
                                cnt = rank_stats.count
                                rel = cnt >= 20 ? "✓" : cnt >= 5 ? "⚠️" : "❌"
                                dir_text = dir == 1 ? "📈" : "📉"
                                dir_clr = f_dir_color(dir, color_bull, color_bear)

                                label_text = str.format("{0}[{1}]{2}({3}){4}", f_sig_emoji(sig), grd, dir_text, cnt, rel)
                                value_text = str.format("{0,number,+#.1;-#.1}%|{1,number,#}%", ret, wr)

                                table.cell(dashboard, 0, row, label_text, text_color=dir_clr, text_size=txt_size_body)
                                table.cell(dashboard, 1, row, value_text, text_color=dir_clr, text_size=txt_size_body)
                                row += 1
                                display_count += 1

                        // 如果没有数据显示提示
                        if display_count == 0
                            table.cell(dashboard, 0, row, "No data yet", text_color=color.gray, text_size=txt_size_body)
                            table.cell(dashboard, 1, row, "Need ≥5 signals", text_color=color.gray, text_size=txt_size_body)

// ────────────────────────────────────────
// SMART ALERT
// ────────────────────────────────────────

varip int buy_alert_level_sent = 0
varip int sell_alert_level_sent = 0

f_signal_level(_mtf, _div, _ext, _norm) =>
    _mtf ? 4 : _div ? 3 : _ext ? 2 : _norm ? 1 : 0

if barstate.isnew
    buy_alert_level_sent := 0
    sell_alert_level_sent := 0

if enable_smart_alert
    // 使用统计过滤后的信号（所有模式都过滤Alert）
    filtered_buy_normal = show_normal_signals and alert_buy_norm
    filtered_sell_normal = show_normal_signals and alert_sell_norm
    alert_has_buy = alert_buy_mtf or alert_buy_div or alert_buy_ext or filtered_buy_normal
    alert_has_sell = alert_sell_mtf or alert_sell_div or alert_sell_ext or filtered_sell_normal

    // Alert-specific icon 选择（基于 alert_* 布尔值，与 Dashboard 独立）
    string alert_buy_icon = switch
        alert_buy_mtf => "🌟MTF共振"
        alert_buy_div => "💎背离"
        alert_buy_ext => "🔥极端"
        filtered_buy_normal => "⬆️超卖"
        => ""
    string alert_sell_icon = switch
        alert_sell_mtf => "🌟MTF共振"
        alert_sell_div => "💎背离"
        alert_sell_ext => "❄️极端"
        filtered_sell_normal => "⬇️超买"
        => ""

    // 过滤状态标记（仅在启用统计过滤时显示）
    string alert_filter_status = (enable_stats_filter and enable_stats) ? (current_signal_passes_filter ? "✓" : "⚠️") : ""

    current_buy_level = f_signal_level(alert_buy_mtf, alert_buy_div, alert_buy_ext, filtered_buy_normal)
    previous_buy_level = f_signal_level(alert_buy_mtf[1], alert_buy_div[1], alert_buy_ext[1], show_normal_signals[1] and alert_buy_norm[1])
    should_alert_buy = alert_has_buy and current_buy_level > previous_buy_level and current_buy_level > buy_alert_level_sent

    if should_alert_buy
        msg = str.format("{0}: 🟢 BUY → {1} ", syminfo.ticker, alert_buy_icon)

        if confirmation_buy
            msg := msg + "✓确认 "
        if reversal_buy
            msg := msg + "↩反转 "
        if realtime_bullish_div
            msg := msg + "⚡实时背离 "

        zscore_pct = f_zscore_to_percentile(rsi_zscore)
        msg := msg + str.format("| RSI:{0,number,#.1} Z:{1,number,#.2}σ (≈P{2,number,#}) [{3}]{4}", rsi, rsi_zscore, zscore_pct, buy_quality_grade, alert_filter_status)

        // 可选：添加风险提示
        if include_risk_in_alerts
            msg := msg + str.format(" | SL:-{0,number,#.1}% TP:+{1,number,#.1}%", buy_sl_pct, buy_tp_pct)

        alert(msg, alert.freq_once_per_bar)
        buy_alert_level_sent := current_buy_level

    current_sell_level = f_signal_level(alert_sell_mtf, alert_sell_div, alert_sell_ext, filtered_sell_normal)
    previous_sell_level = f_signal_level(alert_sell_mtf[1], alert_sell_div[1], alert_sell_ext[1], show_normal_signals[1] and alert_sell_norm[1])
    should_alert_sell = alert_has_sell and current_sell_level > previous_sell_level and current_sell_level > sell_alert_level_sent

    if should_alert_sell
        msg = str.format("{0}: 🔴 SELL → {1} ", syminfo.ticker, alert_sell_icon)

        if confirmation_sell
            msg := msg + "✓确认 "
        if reversal_sell
            msg := msg + "↩反转 "
        if realtime_bearish_div
            msg := msg + "⚡实时背离 "

        zscore_pct = f_zscore_to_percentile(rsi_zscore)
        msg := msg + str.format("| RSI:{0,number,#.1} Z:{1,number,#.2}σ (≈P{2,number,#}) [{3}]{4}", rsi, rsi_zscore, zscore_pct, sell_quality_grade, alert_filter_status)

        // 可选：添加风险提示
        if include_risk_in_alerts
            msg := msg + str.format(" | SL:+{0,number,#.1}% TP:-{1,number,#.1}%", sell_sl_pct, sell_tp_pct)

        alert(msg, alert.freq_once_per_bar)
        sell_alert_level_sent := current_sell_level

// ────────────────────────────────────────
// STRATEGY REPORT EXECUTION
// ────────────────────────────────────────

raw_strategy_buy_signal = sig_buy_mtf or sig_buy_div or sig_buy_extreme or (show_normal_signals and sig_buy_normal)
raw_strategy_sell_signal = sig_sell_mtf or sig_sell_div or sig_sell_extreme or (show_normal_signals and sig_sell_normal)

production_strategy_buy_signal = alert_buy_mtf or alert_buy_div or alert_buy_ext or (show_normal_signals and alert_buy_norm)
production_strategy_sell_signal = alert_sell_mtf or alert_sell_div or alert_sell_ext or (show_normal_signals and alert_sell_norm)

strategy_buy_signal = harness_use_production ? production_strategy_buy_signal : raw_strategy_buy_signal
strategy_sell_signal = harness_use_production ? production_strategy_sell_signal : raw_strategy_sell_signal
strategy_signal_dir = strategy_buy_signal and not strategy_sell_signal ? 1 : strategy_sell_signal and not strategy_buy_signal ? -1 : 0

allow_long_entries = harness_trade_side == "Long Only" or harness_trade_side == "Both"
allow_short_entries = harness_trade_side == "Short Only" or harness_trade_side == "Both"

if strategy_signal_dir == 1
    if strategy.position_size < 0
        strategy.close("Short")
    if allow_long_entries and strategy.position_size <= 0
        strategy.entry("Long", strategy.long)

if strategy_signal_dir == -1
    if strategy.position_size > 0
        strategy.close("Long")
    if allow_short_entries and strategy.position_size >= 0
        strategy.entry("Short", strategy.short)
